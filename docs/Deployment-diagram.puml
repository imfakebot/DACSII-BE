@startuml Soccer Field Booking System - Deployment Diagram

title Sơ đồ Triển khai - Hệ thống Đặt sân bóng đá

node "Client Devices" as Client {
    component "Web Browser" as WebBrowser
    component "Mobile App" as MobileApp
}

node "Cloud Infrastructure" as Cloud {

    cloud "Internet" as Internet

    node "Load Balancer / API Gateway" as LB {
        component "Nginx / AWS ALB" as Proxy
    }

    node "Application Server" as AppServer {
        component "Backend NestJS Application" as NestJSApp
    }

    node "Database Server" as DBServer {
        database "PostgreSQL Database" as PostgreSQLDB
    }

    node "External Services" as External {
        component "Google OAuth Service" as GoogleAuth
        component "Payment Gateway (e.g., Momo, VNPay)" as PaymentGateway
        component "Email Service (e.g., SendGrid)" as EmailService
        component "SMS Service" as SMSService
    }

}

' Relationships
Client --> Internet : requests
Internet --> LB : forwards

LB --> NestJSApp : routes API calls

NestJSApp --> PostgreSQLDB : persistent data storage
NestJSApp --> GoogleAuth : user authentication
NestJSApp --> PaymentGateway : payment processing
NestJSApp --> EmailService : sends emails
NestJSApp --> SMSService : sends SMS

@enduml