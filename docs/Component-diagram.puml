@startuml Soccer Field Booking System - Component Diagram

title Sơ đồ Thành phần - Hệ thống Đặt sân bóng đá

package "Backend Service (NestJS)" as Backend {
    [Auth Module] as Auth
    [User Module] as User
    [Field Module] as Field
    [Booking Module] as Booking
    [Payment Module] as Payment
    [Notification Module] as Notification
    [Branch Module] as Branch
    [Pricing Module] as Pricing
    [Utility Module] as Utility
    [Feedback Module] as Feedback
    [Review Module] as Review
    [Voucher Module] as Voucher

    Auth --> User : manages authentication for
    Auth .> Notification : sends email verification
    Booking --> User : interacts with user data
    Booking --> Field : books fields
    Booking --> Payment : initiates payments
    Booking --> Notification : sends booking confirmations/cancellations
    Field --> Branch : belongs to
    Field --> Pricing : uses pricing rules
    Field --> Utility : has utilities
    Payment --> Voucher : applies vouchers
    User --> Branch : belongs to (staff)
    User --> Voucher : manages user vouchers
    Review --> Booking : reviews booking
    Review --> User : written by
    Review --> Field : for field

    Booking -[hidden]-> Field
    Booking -[hidden]-> Payment
    Booking -[hidden]-> Notification
    Field -[hidden]-> Pricing
    Field -[hidden]-> Utility
    User -[hidden]-> Branch
    User -[hidden]-> Voucher
    Review -[hidden]-> Booking
    Review -[hidden]-> User
    Review -[hidden]-> Field
}

database "PostgreSQL Database" as DB
component "Google OAuth" as GoogleOAuth
component "Payment Gateway (e.g., Momo, VNPay)" as PaymentGateway
component "Email Service (e.g., SendGrid, Nodemailer)" as EmailService
component "SMS Service" as SMSService

Backend --> DB : reads/writes data
Auth --> GoogleOAuth : authenticates via
Payment --> PaymentGateway : processes payments
Notification --> EmailService : sends emails
Notification --> SMSService : sends SMS

@enduml