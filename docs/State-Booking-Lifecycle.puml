@startuml Soccer Field Booking System - State Machine Diagram: Booking Lifecycle

title Sơ đồ Trạng thái - Vòng đời Đặt sân

hide empty description

[*] --> PENDING : Đặt sân mới

state PENDING {
  PENDING --> CONFIRMED : Thanh toán thành công
  PENDING --> FAILED : Thanh toán thất bại / Hết hạn thanh toán
  PENDING --> CANCELLED : Người dùng hủy trước xác nhận
}

state CONFIRMED {
  CONFIRMED --> CHECKED_IN : Khách hàng đến sân
  CONFIRMED --> CANCELLED : Người dùng hủy (có thể mất phí)
  CONFIRMED --> COMPLETED : Tự động hoàn thành sau giờ kết thúc
}

state CHECKED_IN {
  CHECKED_IN --> COMPLETED : Sau giờ kết thúc (Field auto finish)
  CHECKED_IN --> CANCELLED : Huỷ sau khi check-in (có thể có phạt)
}

state FAILED {
  FAILED --> CANCELLED : Tự động hủy nếu không thanh toán lại
}

state CANCELLED {
  CANCELLED --> [*] : Kết thúc vòng đời
}

state COMPLETED {
  COMPLETED --> [*] : Kết thúc vòng đời
}

@enduml
