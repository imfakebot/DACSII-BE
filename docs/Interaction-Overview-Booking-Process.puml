@startuml Soccer Field Booking System - Interaction Overview Diagram: Booking Process

title Sơ đồ Tổng quan Tương tác - Quy trình Đặt sân

frame "Quy trình Đặt sân tổng thể" {
  :Khởi tạo yêu cầu đặt sân;
  -> (Xác minh thông tin sân trống);
  fork
    :Tạo bản ghi Booking tạm thời;
    -> (Xử lý thanh toán);
  fork again
    :Gửi email xác thực người dùng;
    -> (Hoàn thành xác thực người dùng);
  end fork

  :Kiểm tra kết quả thanh toán;
  if (Thanh toán thành công?) then (Có)
    :Xác nhận Booking;
    -> (Gửi thông báo xác nhận);
  else (Không)
    :Hủy Booking;
    -> (Gửi thông báo hủy);
  endif

  partition "Các Diagram liên quan" {
    ref over (Xác minh thông tin sân trống) : Sequence Diagram - Create Booking (checkAvailability)
    ref over (Xử lý thanh toán) : Activity Diagram - Payment Process
    ref over (Xác nhận Booking) : Sequence Diagram - Create Booking (confirmBooking)
    ref over (Gửi thông báo xác nhận) : Sequence Diagram - Create Booking (sendBookingConfirmation)
    ref over (Hoàn thành xác thực người dùng) : Activity Diagram - User Registration
  }
}

@enduml
