@startuml Soccer Field Booking System - Package Diagram: Module Dependencies

title Sơ đồ Gói - Phụ thuộc giữa các Module

' NestJS Application Core
package "Core Application" as Core {
    package "App" as AppModule {
        [AppModule]
    }
    package "Database" as DatabaseModule {
        [DatabaseModule]
    }
    package "Common" as CommonModule {
        [CommonModule]
    }
}

' Domain Modules
package "Domain Features" as Domain {
    package "Auth" as AuthModule {
        [AuthModule]
    }
    package "User" as UserModule {
        [UserModule]
    }
    package "Field" as FieldModule {
        [FieldModule]
    }
    package "Booking" as BookingModule {
        [BookingModule]
    }
    package "Payment" as PaymentModule {
        [PaymentModule]
    }
    package "Notification" as NotificationModule {
        [NotificationModule]
    }
    package "Branch" as BranchModule {
        [BranchModule]
    }
    package "Pricing" as PricingModule {
        [PricingModule]
    }
    package "Utility" as UtilityModule {
        [UtilityModule]
    }
    package "Feedback" as FeedbackModule {
        [FeedbackModule]
    }
    package "Review" as ReviewModule {
        [ReviewModule]
    }
    package "Voucher" as VoucherModule {
        [VoucherModule]
    }
    package "Location" as LocationModule {
        [LocationModule]
    }
    package "Event" as EventModule {
        [EventModule]
    }
}

' Dependencies
AppModule --> AuthModule
AppModule --> UserModule
AppModule --> FieldModule
AppModule --> BookingModule
AppModule --> PaymentModule
AppModule --> NotificationModule
AppModule --> BranchModule
AppModule --> PricingModule
AppModule --> UtilityModule
AppModule --> FeedbackModule
AppModule --> ReviewModule
AppModule --> VoucherModule
AppModule --> LocationModule
AppModule --> EventModule

AuthModule .up.> UserModule : uses
AuthModule .up.> NotificationModule : sends email
BookingModule .up.> UserModule : interacts with
BookingModule .up.> FieldModule : books fields
BookingModule .up.> PaymentModule : initiates
BookingModule .up.> NotificationModule : sends alerts
FieldModule .up.> BranchModule : belongs to
FieldModule .up.> PricingModule : uses rules
FieldModule .up.> UtilityModule : has
PaymentModule .up.> VoucherModule : applies
ReviewModule .up.> BookingModule : reviews
ReviewModule .up.> UserModule : by
ReviewModule .up.> FieldModule : for

' Core dependencies
Domain --> DatabaseModule
Domain --> CommonModule
AppModule --> DatabaseModule
AppModule --> CommonModule

@enduml
